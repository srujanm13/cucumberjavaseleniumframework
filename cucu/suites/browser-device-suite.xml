<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="Browser Device Suite" parallel="tests" thread-count="4" data-provider-thread-count="5" preserve-order="false">

    <test name="Chrome Desktop Smoke">
        <parameter name="browser" value="chrome"/>
        <parameter name="device" value="desktop"/>
        <parameter name="execution" value="local"/>
        <classes>
            <class name="runners.SmokeTestRunner"/>
        </classes>
    </test>

    <test name="Firefox Mobile Negative">
        <parameter name="browser" value="firefox"/>
        <parameter name="device" value="mobile"/>
        <parameter name="execution" value="local"/>
        <classes>
            <class name="runners.NegativeTestRunner"/>
        </classes>
    </test>

    <test name="Edge Tab Negative">
        <parameter name="browser" value="edge"/>
        <parameter name="device" value="tab"/>
        <parameter name="execution" value="local"/>
        <classes>
            <class name="runners.NegativeTestRunner"/>
        </classes>
    </test>

</suite>
